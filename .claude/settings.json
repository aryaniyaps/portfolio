{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/check-gstack.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|CreateFile|Delete",
        "hooks": [
          {
            "type": "command",
            "command": "npx eslint --ext .js,.jsx,.ts,.tsx ."
          },
          {
            "type": "command",
            "command": "ruff check ."
          }
        ]
      }
    ]
  }
}